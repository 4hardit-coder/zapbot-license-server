# ─── SERVIDOR ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── BANCO DE DADOS ──────────────────────────────────────
# Railway fornece essa URL automaticamente
DATABASE_URL=postgresql://user:password@host:port/database

# ─── JWT ─────────────────────────────────────────────────
# Caminho para as chaves RSA geradas com OpenSSL
# As chaves ficam na pasta /keys (nunca commitar private.pem)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Validade do token de licenca (48h de grace period + margem)
LICENSE_TOKEN_EXPIRY=25h

# Secret para tokens JWT do admin (gerar string aleatoria longa)
JWT_ADMIN_SECRET=troque-por-uma-string-aleatoria-longa-aqui

# ─── ADMIN ───────────────────────────────────────────────
ADMIN_EMAIL=4hard.it@gmail.com
# Gerar com: node -e "const b=require('bcryptjs');console.log(b.hashSync('SUA_SENHA',12))"
ADMIN_PASSWORD_HASH=

# ─── EMAIL (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=4Hard Zap-Marketing <onboarding@resend.dev>
EMAIL_REPLY_TO=4hard.it@gmail.com

# ─── HOTMART ─────────────────────────────────────────────
# Encontrar em: Hotmart > Ferramentas > Webhooks > hottok
HOTMART_HOTTOK=seu-hottok-aqui

# ─── CORS ────────────────────────────────────────────────
# URL do painel admin em producao
CORS_ORIGIN=https://empowering-acceptance-production-1eec.up.railway.app
